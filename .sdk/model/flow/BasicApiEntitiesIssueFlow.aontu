# BasicApiEntitiesIssueFlow

main: kit: flow: BasicApiEntitiesIssueFlow:
{
  entity: "api_entities_issue",
  kind: "basic",
  name: "BasicApiEntitiesIssueFlow",
  step: [
    {
      input: {
        ref: "api_entities_issue_ref01"
      }

      match: {
        group_id: "group01",
        project_id: "project01"
      }

      op: "create"
    }

    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "api_entities_issue_ref01"
          }
        }
      ]
    }

    {
      data: {
        project_id: "project01"
      }

      input: {
        ref: "api_entities_issue_ref01",
        srcdatavar: "api_entities_issue_ref01_data",
        suffix: "_up0",
        textfield: "blocking_issues_count"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-api_entities_issue_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "api_entities_issue_ref01",
        srcdatavar: "api_entities_issue_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "api_entities_issue01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-api_entities_issue_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicApiEntitiesIssueFlow"
}
# BasicUserFlow

main: kit: flow: BasicUserFlow:
{
  entity: "user",
  kind: "basic",
  name: "BasicUserFlow",
  step: [
    {
      match: {
        project_id: "project01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "user_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicUserFlow"
}
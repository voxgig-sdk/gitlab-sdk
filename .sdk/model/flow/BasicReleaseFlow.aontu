# BasicReleaseFlow

main: kit: flow: BasicReleaseFlow:
{
  entity: "release",
  kind: "basic",
  name: "BasicReleaseFlow",
  step: [
    {
      input: {
        ref: "release_ref01",
        srcdatavar: "release_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "release01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-release_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicReleaseFlow"
}
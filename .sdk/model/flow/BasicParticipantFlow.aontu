# BasicParticipantFlow

main: kit: flow: BasicParticipantFlow:
{
  entity: "participant",
  kind: "basic",
  name: "BasicParticipantFlow",
  step: [
    {
      match: {
        merge_request_id: "merge_request01",
        project_id: "project01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "participant_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicParticipantFlow"
}
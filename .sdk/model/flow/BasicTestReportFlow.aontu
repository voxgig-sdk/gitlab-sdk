# BasicTestReportFlow

main: kit: flow: BasicTestReportFlow:
{
  entity: "test_report",
  kind: "basic",
  name: "BasicTestReportFlow",
  step: [
    {
      match: {
        pipeline_id: "pipeline01",
        project_id: "project01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "test_report_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicTestReportFlow"
}